# Cruzible backend environment example
#
# This file documents backend-side variables used by:
# - backend/api runtime
# - backend/infra/docker-compose.yml scaffolding
#
# Important: backend/api currently reads from process.env only. It does not
# auto-load this file. Use your shell, process manager, container runtime, or
# secret store to inject the values you need.

# -----------------------------------------------------------------------------
# API runtime variables (validated or consumed by backend/api)
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=3001

# RPC endpoint used by BlockchainService and health/readiness checks
RPC_URL=http://127.0.0.1:26657

# Prisma connection string used by the API and reconciliation/indexer services
DATABASE_URL=postgresql://cruzible:change-me@localhost:5432/cruzible?schema=public

# Redis connection string used by API cache. Required when NODE_ENV=production.
REDIS_URL=redis://localhost:6379

# Comma-separated allowed origins. In production, wildcard origins are rejected.
CORS_ORIGINS=http://localhost:3000

# Replace these before any shared or production deployment.
JWT_SECRET=replace-with-a-32-character-or-longer-secret
JWT_REFRESH_SECRET=replace-with-a-32-character-or-longer-refresh-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Express trust proxy setting. Use an explicit hop count such as "1" behind
# a managed ingress; production startup rejects unbounded "true".
TRUST_PROXY=loopback

# Global API rate limiting. /health/live and /health/ready are exempt.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Operational surfaces. Metrics are enabled by default; API docs default to
# disabled in production when unset. Production API startup requires
# OPERATIONAL_ENDPOINTS_TOKEN whenever metrics or docs are exposed.
METRICS_ENABLED=true
API_DOCS_ENABLED=true
OPERATIONAL_ENDPOINTS_TOKEN=replace-with-a-32-character-or-longer-ops-token

# Development-only escape hatch for mocked signature verification.
# The API refuses to start with this enabled in production.
ALLOW_MOCK_SIGNATURES=false

# Comma-separated aeth1 wallet addresses that receive operator/admin roles at login.
# Production startup requires at least one operator-capable wallet.
AUTH_OPERATOR_ADDRESSES=
AUTH_ADMIN_ADDRESSES=

# Wallet login nonce lifetime and route-specific auth/ops rate limits.
AUTH_NONCE_TTL_MS=300000
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
OPS_RATE_LIMIT_WINDOW_MS=60000
OPS_RATE_LIMIT_MAX=60

# Indexer controls consumed by backend/api.
INDEXER_ENABLED=true
INDEXER_RPC_URL=http://127.0.0.1:8545
INDEXER_WS_URL=ws://127.0.0.1:8546
INDEXER_START_BLOCK=0

# Contract addresses used by indexer/reconciliation flows.
CRUZIBLE_VAULT_ADDRESS=
STAETHEL_ADDRESS=
STABLECOIN_BRIDGE_ADDRESS=

# Optional alert delivery integration.
ALERT_WEBHOOK_URL=
ALERT_RATE_LIMIT_MS=300000

# Reconciliation scheduler tuning.
RECONCILIATION_INTERVAL_MS=300000
RECONCILIATION_MIN_VALIDATORS=4
RECONCILIATION_EPOCH_DURATION_S=3600
RECONCILIATION_RATE_WARN_PCT=0.01
RECONCILIATION_RATE_CRIT_PCT=0.05
RECONCILIATION_TVL_DRIFT_PCT=0.02

# -----------------------------------------------------------------------------
# Docker Compose / infrastructure scaffold variables
# -----------------------------------------------------------------------------
#
# These are referenced by backend/infra/docker-compose.yml. Some of them are
# not consumed directly by backend/api in the current snapshot.

CHAIN_ID=aethelred-testnet-1
MONIKER=cruzible-local
MINIMUM_GAS_PRICES=0.025aeth
PRUNING=default
INDEXER=kv

DB_USER=cruzible
DB_PASSWORD=change-me
DB_NAME=cruzible

# Compose currently uses these names for indexer scaffolding. If you also run
# backend/api directly, set INDEXER_START_BLOCK above as well.
INDEXER_START_HEIGHT=0
INDEXER_BATCH_SIZE=100

GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me
GRAFANA_ROOT_URL=http://localhost:3002

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
#
# - GRPC_URL is passed through some deployment scaffolding, but the current
#   backend/api config contract is centered on the variables above.
# - backend/infra/docker-compose.yml references additional config directories
#   not present in this workspace. Treat it as a baseline, not a turnkey stack.
