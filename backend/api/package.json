{
  "name": "@aethelred/api-gateway",
  "version": "1.0.0",
  "description": "Aethelred API Gateway - High-performance REST/WebSocket API for blockchain interaction",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "prisma generate && npm --prefix ../../sdk/typescript run build",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "node --max-old-space-size=8192 dist/index.js",
    "test": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:integration": "echo 'Integration tests not yet implemented — skipping' && exit 0",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "prisma generate && npm --prefix ../../sdk/typescript run build && tsc --noEmit -p tsconfig.json",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "redis:generate": "redis-commander",
    "benchmark": "autocannon -c 100 -d 30 http://localhost:3000/v1/health"
  },
  "dependencies": {
    "@cosmjs/amino": "^0.32.0",
    "@cosmjs/cosmwasm-stargate": "^0.32.0",
    "@cosmjs/crypto": "^0.32.0",
    "@cosmjs/encoding": "^0.32.0",
    "@cosmjs/math": "^0.32.0",
    "@cosmjs/proto-signing": "^0.32.0",
    "@cosmjs/stargate": "^0.32.0",
    "@cosmjs/tendermint-rpc": "^0.32.0",
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.0",
    "@prisma/client": "^5.7.0",
    "@sentry/node": "^7.88.0",
    "@sentry/profiling-node": "^7.88.0",
    "@trpc/server": "^10.45.0",
    "bullmq": "^4.16.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "long": "^5.2.3",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.4",
    "node-cache": "^5.1.2",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "prom-client": "^15.1.0",
    "protobufjs": "^7.2.5",
    "reflect-metadata": "^0.2.1",
    "socket.io": "^4.7.0",
    "superjson": "^2.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "tsyringe": "^4.8.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^1.1.0",
    "autocannon": "^7.14.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0",
    "redis-commander": "^0.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "keywords": [
    "blockchain",
    "api",
    "aethelred",
    "rest",
    "websocket",
    "cosmos-sdk"
  ],
  "author": "Aethelred Labs <dev@aethelred.org>",
  "license": "Apache-2.0"
}
