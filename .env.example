# Cruzible frontend environment example
#
# Copy to .env.local for local Next.js development.
# The variables below are limited to values referenced from src/.

# -----------------------------------------------------------------------------
# Core frontend configuration
# -----------------------------------------------------------------------------

# Frontend environment selector used by src/config/chains.ts
# Supported values in the current snapshot: mainnet, testnet, devnet
NEXT_PUBLIC_CHAIN_ENV=testnet

# Base URL for backend API requests. Production public-data requests fail closed
# when this is unset, and mainnet/testnet mismatches are rejected.
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# Optional display/version string surfaced in the UI and request headers
NEXT_PUBLIC_APP_VERSION=local-dev

# WalletConnect project id. Leave blank if you are not testing WalletConnect.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# -----------------------------------------------------------------------------
# Contract addresses
# -----------------------------------------------------------------------------
#
# Leave blank until the corresponding contracts are deployed for the selected
# environment. Governance is still preview-oriented in the current workspace.

NEXT_PUBLIC_CRUZIBLE_ADDRESS=
NEXT_PUBLIC_STAETHEL_ADDRESS=
NEXT_PUBLIC_AETHEL_TOKEN_ADDRESS=
NEXT_PUBLIC_GOVERNANCE_ADDRESS=
NEXT_PUBLIC_STABLECOIN_BRIDGE_ADDRESS=
NEXT_PUBLIC_USDC_TOKEN_ADDRESS=
NEXT_PUBLIC_USDT_TOKEN_ADDRESS=

# -----------------------------------------------------------------------------
# Developer tools page
# -----------------------------------------------------------------------------
#
# Used by /devtools when running local verifier and RPC dependencies.
# Production hides /devtools unless this is explicitly set to true.

NEXT_PUBLIC_ENABLE_DEVTOOLS=false
NEXT_PUBLIC_DEVTOOLS_FASTAPI_URL=http://127.0.0.1:8000
NEXT_PUBLIC_DEVTOOLS_NEXTJS_URL=http://127.0.0.1:3000
NEXT_PUBLIC_DEVTOOLS_RPC_URL=http://127.0.0.1:26657
