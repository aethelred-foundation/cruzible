{
  "name": "@aethelred/cruzible",
  "version": "1.0.0",
  "description": "Aethelred Blockchain Explorer and Dashboard - Production Grade",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{js,mjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{js,mjs,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:changed": "vitest related --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "security:audit": "npm audit --audit-level=moderate",
    "analyze": "cross-env ANALYZE=true next build",
    "postbuild": "next-sitemap",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@sentry/nextjs": "^10.46.0",
    "@tanstack/react-query": "^5.17.9",
    "@vercel/analytics": "^1.1.1",
    "@vercel/speed-insights": "^1.0.2",
    "@walletconnect/ethereum-provider": "^2.13.0",
    "autoprefixer": "^10.4.17",
    "clsx": "^2.1.0",
    "lucide-react": "^0.311.0",
    "next": "^15.5.14",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "recharts": "^2.10.3",
    "sharp": "^0.33.1",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.1",
    "viem": "^2.17.0",
    "wagmi": "^2.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.14",
    "@next/bundle-analyzer": "^15.5.14",
    "@playwright/test": "^1.40.1",
    "@tailwindcss/forms": "^0.5.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "husky": "^8.0.3",
    "jsdom": "^29.0.1",
    "lint-staged": "^15.2.0",
    "msw": "^2.1.2",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "defu": "6.1.7",
    "lodash": "4.18.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
